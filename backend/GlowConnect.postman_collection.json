{
  "info": {
    "name": "GlowConnect API",
    "description": "Full API collection for GlowConnect — auth, users, posts, comments, follow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ayesha\",\n  \"email\": \"ayesha@example.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Ayesha Altaf\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ayesha@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/verify"
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Full-stack dev intern building GlowConnect ✨\"\n}"
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/search?q=ayesha"
          }
        },
        {
          "name": "Follow / Unfollow User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId}}/follow"
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/me/avatar",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "avatar", "type": "file", "src": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/posts",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "content", "value": "Hello GlowConnect!", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/{{postId}}"
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/posts/{{postId}}",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "content", "value": "Updated content", "type": "text" }]
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/posts/{{postId}}"
          }
        },
        {
          "name": "Get Feed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/posts/feed?page=1&limit=10"
          }
        },
        {
          "name": "Get Posts by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/user/{{userId}}?page=1&limit=10"
          }
        },
        {
          "name": "Toggle Like",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/posts/{{postId}}/like"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/posts/{{postId}}/comments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great post!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/comments/{{commentId}}"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
